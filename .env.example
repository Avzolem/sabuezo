# ============================================================
# Sabuezo — env vars (copia a .env y rellena)
# ============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=your-anthropic-key-here

# --- Supabase ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# --- Backend ---
BACKEND_PORT=8787
BACKEND_HOST=0.0.0.0
# Token compartido bot <-> backend (cualquier string random)
INTERNAL_API_TOKEN=cambia-esto-por-uno-random

# --- Bot WhatsApp ---
# URL del backend desde el bot (mismo host por defecto)
BACKEND_URL=http://localhost:8787

# --- Opcionales / nice-to-have ---
GOOGLE_SAFE_BROWSING_API_KEY=
HIBP_API_KEY=
# URLScan.io: sin key funciona la búsqueda pública (inteligencia colectiva).
# Con key, además somete scans nuevos con screenshot. Gratis en urlscan.io.
URLSCAN_API_KEY=
